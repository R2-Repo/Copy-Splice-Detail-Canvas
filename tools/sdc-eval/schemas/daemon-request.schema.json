{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "sdc-eval-daemon-request",
  "title": "DaemonRequest",
  "type": "object",
  "required": ["id", "command"],
  "properties": {
    "id": { "type": "string" },
    "command": {
      "enum": [
        "ping",
        "shutdown",
        "parse",
        "analyze-topology",
        "search",
        "evaluate",
        "evaluate-tier",
        "evaluate-batch",
        "rules",
        "import-rules",
        "export-top"
      ]
    },
    "payload": { "type": "object" }
  }
}
