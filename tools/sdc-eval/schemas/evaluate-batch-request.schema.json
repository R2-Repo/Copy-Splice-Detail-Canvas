{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "sdc-eval-evaluate-batch-request",
  "title": "EvaluateBatchRequest",
  "type": "object",
  "required": ["candidates"],
  "oneOf": [
    { "required": ["csvPath", "candidates"] },
    { "required": ["csvText", "candidates"] },
    { "required": ["graph", "candidates"] },
    { "required": ["sessionKey", "candidates"] }
  ],
  "properties": {
    "csvPath": { "type": "string" },
    "csvText": { "type": "string" },
    "graph": { "$ref": "connection-graph.schema.json" },
    "sessionKey": { "type": "string" },
    "candidates": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "layout-candidate.schema.json" }
    },
    "maxTier": { "enum": ["T0", "T1", "T2"] },
    "bestScore": { "type": "number" }
  }
}
